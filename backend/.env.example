GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
FRONTEND_ORIGINS=http://localhost:3000

# Login admin untuk membuka dashboard lengkap
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Opsional. Kalau kosong, backend membuat token otomatis setiap start.
APP_AUTH_TOKEN=

# Opsional.
# Kalau kosong, data pencarian publik otomatis dibuat di backend/data/public_lookup.xlsx
# ketika admin klik Generate Excel Final.
# Untuk deploy dengan persistent disk, contoh: PUBLIC_LOOKUP_FILE=/data/public_lookup.xlsx
PUBLIC_LOOKUP_FILE=
